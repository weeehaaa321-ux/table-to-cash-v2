# ─── Required ───────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, etc.)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Restaurant config ─────────────────────────
NEXT_PUBLIC_RESTAURANT_SLUG="neom-dahab"
NEXT_PUBLIC_RESTAURANT_NAME="Neom Dahab"
NEXT_PUBLIC_RESTAURANT_TZ="Africa/Cairo"
NEXT_PUBLIC_RESTAURANT_CURRENCY="EGP"

# ─── Staff access PIN ─────────────────────────
# PIN required to access staff pages (dashboard, kitchen, waiter, etc.)
NEXT_PUBLIC_STAFF_PIN=""

# ─── Web Push (VAPID keys) ─────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.com"

# ─── Cron job authentication ───────────────────
# Required in production — cron endpoints reject all requests without it
CRON_SECRET=""

# ─── Error tracking (Sentry) ──────────────────
# Create a project at sentry.io and paste the DSN here
NEXT_PUBLIC_SENTRY_DSN=""

# ─── Build metadata (auto-set on Vercel) ───────
# NEXT_PUBLIC_BUILD_ID=""
